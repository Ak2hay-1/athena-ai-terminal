# Application
APP_NAME=Athena AI Terminal
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/athena

# JWT Authentication
SECRET_KEY=change-me-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# MetaTrader 5
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# Market (comma-separated)
MARKET_SYMBOLS=XAUUSD,EURUSD,GBPUSD,USDJPY,AUDUSD,USDCAD,NZDUSD,USDCHF
MARKET_TIMEFRAMES=M1,M5,M15
DEFAULT_SYMBOL=XAUUSD
DEFAULT_TIMEFRAME=M1

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT=300

# Scheduler
SCHEDULER_TIMEZONE=Asia/Kolkata
COLLECTOR_INTERVAL_SECONDS=60

# News
NEWS_API_KEY=
NEWS_SYNC_INTERVAL=900
NEWS_BLOCK_MINUTES=30
NEWS_SENTIMENT_WEIGHT=15
NEWS_RSS_FEEDS=https://www.forexfactory.com/ffcal_week_this.xml

# Learning
LEARNING_ENABLED=true
LEARNING_MIN_SAMPLES=50
LEARNING_RETRAIN_INTERVAL_HOURS=168
LEARNING_MODEL_PATH=storage/learning

# Trading
EXECUTION_PROVIDER=paper
MAX_OPEN_TRADES=5
MAX_RISK_PERCENT=2.0

# CORS (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
