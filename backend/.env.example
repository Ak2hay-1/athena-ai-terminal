# Application
APP_NAME=Athena AI Terminal
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# Database
# Local host: localhost. Docker Compose API service: use host "postgres"
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/athena

# JWT Authentication
# REQUIRED: replace before any shared/deployed use
SECRET_KEY=change-me-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# MetaTrader 5 (REQUIRED for live candles/ticks)
# Run the API on the same Windows host as the MT5 terminal (Linux/Docker cannot use MT5).
# Leave blank → charts stay empty ("No candle data… Backfill from MT5").
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=
# Optional absolute path to terminal64.exe if auto-detect fails, e.g.:
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_PATH=

# Max seconds to wait for mt5.initialize() during startup before giving up
# and continuing without MT5 (prevents the API from hanging forever when
# the MT5 terminal isn't installed/running).
MT5_INIT_TIMEOUT=15

# Realtime tick stream (MT5 symbol_info_tick → WebSocket type=tick)
TICK_STREAM_ENABLED=true
TICK_POLL_MS=200

# Market (comma-separated)
MARKET_SYMBOLS=XAUUSD,XAGUSD,EURUSD,GBPUSD,USDJPY,AUDUSD,USDCAD,NZDUSD,USDCHF,EURJPY,GBPJPY,EURGBP
MARKET_TIMEFRAMES=M1,M5,M15,M30,H1,H4,D1
DEFAULT_SYMBOL=XAUUSD
DEFAULT_TIMEFRAME=M5
# Bars per single MT5 call during deep/backfill pulls (broker maxbars may clamp lower)
MARKET_COLLECTOR_BARS=50000
# Bars per routine scheduled collect (every symbol x timeframe). Keep small —
# only needs to cover the newest bar(s) since the last poll.
MARKET_COLLECTOR_POLL_BARS=10
# Max bars for POST /api/v1/market/backfill
MARKET_BACKFILL_BARS=100000
# One-shot deep backfill on scheduler start when candle_count is below threshold
MARKET_STARTUP_BACKFILL_ENABLED=true
MARKET_STARTUP_BACKFILL_THRESHOLD=5000

# --- Market Data Engine (tick -> candle pipeline) ---
# Master switch: build candles from live MT5 ticks; local DB is the
# primary history source, MT5 fills gaps only.
MARKET_ENGINE_ENABLED=true
# Target depth of the one-time initial history download (years of M1;
# limited by broker history availability)
MARKET_INITIAL_SYNC_YEARS=5
# Persist raw ticks to market_ticks (backtesting / future ML)
MARKET_STORE_TICKS=false
# Seconds between batched DB flushes of completed candles
MARKET_WRITE_FLUSH_SECONDS=1.0
# Run local analysis after each candle close
MARKET_ANALYZE_ON_CLOSE=true

# --- Multi-layer Market Cache (RAM → DB → MT5) ---
# Chart history / indicators / short AI context. Never caches account state.
CACHE_ENABLED=true
CACHE_MAX_RAM_CANDLES=5000
CACHE_MAX_RAM_MB=256
CACHE_MAX_SERIES=128
CACHE_INACTIVE_TTL_SECONDS=900
CACHE_PRELOAD_ENABLED=true
CACHE_PRELOAD_WORKERS=2
CACHE_PRELOAD_LIMIT=500
CACHE_PRELOAD_TIMEFRAMES=M1,M15,H1,H4
CACHE_INDICATOR_ENABLED=true
# AI market-context TTL (seconds); keep 30–60
CACHE_AI_TTL_SECONDS=45

# AI Provider (local | azure | gemini | openai | claude | deepseek | grok)
# Default for this stack: local Ollama. Cloud providers remain plug-and-play.
AI_PROVIDER=local
AI_FALLBACK_PROVIDER=local
AI_TIMEOUT=60
AI_MAX_RETRIES=3
AI_CACHE_TTL_SECONDS=3600
REDIS_URL=redis://localhost:6379/0

# Azure OpenAI (GPT-5 Mini)
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Optional: separate embeddings deployment name
AZURE_OPENAI_EMBED_DEPLOYMENT=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

# OpenAI (also used for deepseek/grok via AI_BASE_URL)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_BASE_URL=

# Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama (local provider) — model names are Ollama tags (llama3, mistral, qwen, deepseek, phi, …)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=300
OLLAMA_MAX_RETRIES=3
OLLAMA_TEMPERATURE=0.3
OLLAMA_TOP_P=0.9
OLLAMA_MAX_TOKENS=1024

# Scheduler
SCHEDULER_TIMEZONE=Asia/Kolkata
COLLECTOR_INTERVAL_SECONDS=60

# News
NEWS_API_KEY=
NEWS_SYNC_INTERVAL=900
NEWS_BLOCK_MINUTES=30
NEWS_SENTIMENT_WEIGHT=15
NEWS_RSS_FEEDS=https://www.forexfactory.com/ffcal_week_this.xml

# Learning
LEARNING_ENABLED=true
LEARNING_MIN_SAMPLES=50
LEARNING_RETRAIN_INTERVAL_HOURS=168
LEARNING_MODEL_PATH=storage/learning
LEARNING_OUTCOME_HORIZON_CANDLES=10
LEARNING_LABEL_INTERVAL_SECONDS=900
LEARNING_ANALYTICS_INTERVAL_SECONDS=3600
LEARNING_ANALYTICS_MIN_SAMPLES=10
LEARNING_WEIGHT_UPDATE_INTERVAL_HOURS=24
LEARNING_WEIGHT_MIN_SAMPLES=50
LEARNING_WEIGHT_STEP=2.0
LEARNING_WEIGHT_MAX_STEP=1.5
LEARNING_WEIGHT_MIN=5.0
LEARNING_WEIGHT_MAX=35.0
ENGINE_VERSION=1.0.0
INDICATOR_VERSION=1.0.0
STRATEGY_VERSION=1.0.0
LEARNING_SYSTEM_VERSION=1.0.0

# Trade Probability (deterministic; no AI)
PROBABILITY_LOW_SAMPLE=20
PROBABILITY_BLEND_MIN=30
PROBABILITY_CANDIDATE_LIMIT=500
PROBABILITY_SIMILAR_TOP_N=20
SIMILARITY_WEIGHT_TREND=0.25
SIMILARITY_WEIGHT_STRUCTURE=0.20
SIMILARITY_WEIGHT_LIQUIDITY=0.15
SIMILARITY_WEIGHT_MOMENTUM=0.15
SIMILARITY_WEIGHT_NEWS=0.10
SIMILARITY_WEIGHT_ATR=0.10
SIMILARITY_WEIGHT_RISK=0.05

# Trading
# MT5 only — Dashboard "Execute trade" and Auto Trade place BUY_LIMIT/SELL_LIMIT
# at entry+SL+TP (requires working MT5_* credentials above).
# Auto Trade filters (pairs, confidence, etc.) are per-user preferences in the API/UI.
EXECUTION_PROVIDER=mt5
MAX_OPEN_TRADES=5
MAX_RISK_PERCENT=2.0
RISK_REWARD_RATIO=2.0
ATR_MULTIPLIER=2.0
MIN_STOP_PIPS=15

# Institutional risk engine
MIN_RR=1.8
PREFERRED_RR=2.5
MAX_RR=4.0
SL_BUFFER_ATR_FRACTION=0.15
MIN_SL_ATR_FRACTION=0.75
ATR_MIN_FRACTION_OF_PRICE=0.00015
REQUIRE_BOS=true
REQUIRE_CHOCH=false
VOLUME_AVG_LOOKBACK=20
VOLUME_MIN_RATIO=0.8
STRUCTURE_LOOKBACK_BARS=80

# Institutional qualification desk (quality over quantity)
QUALIFICATION_ENABLED=true
MIN_SETUP_QUALITY=75
MIN_CONFIDENCE=70
MAX_ACTIONABLE_TRADES=3
MAX_WATCHLIST=8
QUAL_MIN_ADX=22
QUAL_MIN_STRUCTURE_SCORE=40
QUAL_MAX_SPREAD_FRACTION=0.00035
QUAL_ENFORCE_SESSION=false
QUAL_MTF_REQUIRE_STRICT=true
QUAL_MTF_REQUIRED_ALIGNMENT=H4,H1
ALLOW_CORRELATED_TRADES=false
MAX_CORRELATED_EXPOSURE=1
MAX_SIMULTANEOUS_BUYS=3
MAX_SIMULTANEOUS_SELLS=3
MAX_PORTFOLIO_RISK_PERCENT=6.0
SETUP_LIFECYCLE_ENABLED=true
SETUP_MAX_AGE_MINUTES=240
PORTFOLIO_AWARENESS_ENABLED=true

# Agents (orchestrator) — set true so MarketUpdated from market_data_engine
# reaches Technical/SMC/etc. Off does not affect the trading engine itself.
AGENTS_ENABLED=true
AGENTS_EVENT_HISTORY_SIZE=500
# Comma-separated agent ids to force-disable (e.g. market_watch,technical)
AGENTS_DISABLED=

# Market Watch Agent
# Timeframe codes: M1=1m, M5=5m, M15=15m, H1=1h, H4=4h, D1=daily
MARKET_WATCH_SYMBOLS=EURUSD,GBPUSD,USDJPY,XAUUSD
MARKET_WATCH_TIMEFRAMES=M1,M5,M15,H1,H4,D1
MARKET_WATCH_SCAN_INTERVAL_SECONDS=60
MARKET_WATCH_CANDLE_LIMIT=200
MARKET_WATCH_VOLUME_SPIKE_RATIO=2.0
MARKET_WATCH_ATR_EXPANSION_RATIO=1.5
MARKET_WATCH_GAP_ATR_FRACTION=0.5

# Scanner (ranked opportunity board)
SCANNER_SYMBOLS=XAUUSD,XAGUSD,EURUSD,GBPUSD,USDJPY,AUDUSD,USDCAD,NZDUSD,USDCHF,EURJPY,GBPJPY,EURGBP
SCANNER_SECONDARY_TIMEFRAMES=M15,H1,H4
SCANNER_STALE_MINUTES=45
SCANNER_STRONG_SIGNAL_CONFIDENCE=75
SCANNER_MARKET_WATCH_MAX_AGE_SECONDS=300
SCANNER_MIN_SCORE_DEFAULT=0

# Technical Agent
TECHNICAL_INDICATOR_CACHE_SIZE=256
# TECHNICAL_SCORE_WEIGHTS uses code defaults (trend/momentum/volatility/volume/structure)

# SMC Agent
SMC_INDICATOR_CACHE_SIZE=256
# SMC_SCORE_WEIGHTS uses code defaults

# Risk Agent (evidence only — not execution)
RISK_ACCOUNT_BALANCE=10000
RISK_MAX_SPREAD_POINTS=30
RISK_EXTREME_ATR_RATIO=2.0
RISK_CACHE_SIZE=256

# Validation Agent
VALIDATION_MIN_TECHNICAL_SCORE=60
VALIDATION_MIN_SMC_SCORE=60
VALIDATION_MIN_RISK_SCORE=60
VALIDATION_MIN_RR=1.8
VALIDATION_MIN_CONFLUENCE=70
VALIDATION_CACHE_SIZE=256

# Phase 4 — Memory / Learning / News / Reasoning
MEMORY_AGENT_ENABLED=true
LEARNING_AGENT_ENABLED=true
NEWS_AGENT_ENABLED=true
REASONING_ENABLED=true
REASONING_MIN_CONFLUENCE=70
REASONING_MIN_STATUS=APPROVED
REASONING_CACHE_TTL_SECONDS=3600
REASONING_MAX_RETRIES=2
REASONING_SIMILAR_TRADES_TOP_K=20
MEMORY_SIMILARITY_TOP_K=20
MEMORY_EMBEDDINGS_ENABLED=false
LEARNING_SCAN_INTERVAL_SECONDS=300
NEWS_AGENT_SCAN_INTERVAL_SECONDS=900
# Reasoning uses AZURE_OPENAI_DEPLOYMENT=gpt-5-mini when AI_PROVIDER=azure

# Phase 5 — Portfolio / Watchlist / Communication / Notifications
PORTFOLIO_AGENT_ENABLED=true
WATCHLIST_AGENT_ENABLED=true
COMMUNICATION_AGENT_ENABLED=true
PERSONALIZATION_ENABLED=true
PORTFOLIO_SCAN_INTERVAL_SECONDS=60
PORTFOLIO_ACCOUNT_BALANCE=10000
WATCHLIST_MIN_CONFLUENCE=75
WATCHLIST_DEDUP_TTL_SECONDS=300
COMM_DEDUP_TTL_SECONDS=300
COMM_GROUP_WINDOW_SECONDS=60
COMM_DEFAULT_QUIET_START=22:00
COMM_DEFAULT_QUIET_END=07:00
NOTIFY_TELEGRAM_ENABLED=false
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_DISCORD_ENABLED=false
NOTIFY_DISCORD_WEBHOOK_URL=
NOTIFY_EMAIL_ENABLED=false
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASSWORD=
NOTIFY_SMTP_FROM=
NOTIFY_PUSH_ENABLED=false
NOTIFY_WEBSOCKET_ENABLED=true

# CORS (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:5173,http://127.0.0.1:5173

# Logging
LOG_LEVEL=INFO
