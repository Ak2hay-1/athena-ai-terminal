# Application
APP_NAME=Athena AI Terminal
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/athena

# JWT Authentication
SECRET_KEY=change-me-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# MetaTrader 5
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# Market (comma-separated)
MARKET_SYMBOLS=XAUUSD,XAGUSD,EURUSD,GBPUSD,USDJPY,AUDUSD,USDCAD,NZDUSD,USDCHF,EURJPY,GBPJPY,EURGBP,BTCUSD,ETHUSD,SOLUSD
MARKET_TIMEFRAMES=M1,M5,M15
DEFAULT_SYMBOL=XAUUSD
DEFAULT_TIMEFRAME=M5

# AI Provider (gemini | openai | claude | deepseek | grok | local)
AI_PROVIDER=gemini
AI_FALLBACK_PROVIDER=local
AI_TIMEOUT=60
AI_MAX_RETRIES=3
AI_CACHE_TTL_SECONDS=3600
REDIS_URL=redis://localhost:6379/0

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

# OpenAI (also used for deepseek/grok via AI_BASE_URL)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_BASE_URL=

# Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama (local provider)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=300
OLLAMA_MAX_RETRIES=3

# Scheduler
SCHEDULER_TIMEZONE=Asia/Kolkata
COLLECTOR_INTERVAL_SECONDS=60

# News
NEWS_API_KEY=
NEWS_SYNC_INTERVAL=900
NEWS_BLOCK_MINUTES=30
NEWS_SENTIMENT_WEIGHT=15
NEWS_RSS_FEEDS=https://www.forexfactory.com/ffcal_week_this.xml

# Learning
LEARNING_ENABLED=true
LEARNING_MIN_SAMPLES=50
LEARNING_RETRAIN_INTERVAL_HOURS=168
LEARNING_MODEL_PATH=storage/learning

# Trading
EXECUTION_PROVIDER=paper
MAX_OPEN_TRADES=5
MAX_RISK_PERCENT=2.0
RISK_REWARD_RATIO=2.0
ATR_MULTIPLIER=2.0
MIN_STOP_PIPS=15

# Institutional risk engine
MIN_RR=1.8
PREFERRED_RR=2.5
MAX_RR=4.0
SL_BUFFER_ATR_FRACTION=0.15
MIN_SL_ATR_FRACTION=0.75
ATR_MIN_FRACTION_OF_PRICE=0.00015
REQUIRE_BOS=true
REQUIRE_CHOCH=false
VOLUME_AVG_LOOKBACK=20
VOLUME_MIN_RATIO=0.8
STRUCTURE_LOOKBACK_BARS=80

# CORS (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Logging
LOG_LEVEL=INFO
